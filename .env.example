# Docker Compose reads this file automatically when you run `docker compose up`.
# Use an absolute host path for the media directory you want to expose inside the container.
MEDIA_ROOT=/Users/s_mash/Pictures/ScreenShots

# Optional. Set this only if you want to force a specific LAN URL for the frontend.
# Leave it blank to let the frontend derive the public host from the browser request.
PUBLIC_API_BASE_URL=
